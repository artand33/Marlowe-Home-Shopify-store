<style>
  @media (max-width: 768px) {
    .announcement-bar__arrow {
      display: none !important;
    }

    .announcement-bar {
      padding: 10px 0;
    }

    .announcement-bar__inner {
      gap: 0;
      padding: 0 16px;
    }

    .announcement-bar__messages {
      flex: 1;
      width: 100%;
      min-height: 1.4em;
      max-height: 1.4em;
      text-align: center;
    }

    .announcement-bar__message,
    .announcement-bar__message.is-active {
      position: absolute;
      left: 0;
      top: 0;
      width: 100%;
      max-width: 100%;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      line-height: 1.4;
      font-size: clamp(0.65rem, 2.8vw, 0.8rem);
    }

    .announcement-bar__message.is-active {
      opacity: 1;
    }
  }
</style>

<div class="announcement-bar">
  <div class="announcement-bar__inner">
    <button class="announcement-bar__arrow announcement-bar__arrow--prev" aria-label="Previous">&#8592;</button>
    <div class="announcement-bar__messages">
      <span class="announcement-bar__message">{{ section.settings.message_1 }}</span>
      <span class="announcement-bar__message">{{ section.settings.message_2 }}</span>
      <span class="announcement-bar__message">{{ section.settings.message_3 }}</span>
    </div>
    <button class="announcement-bar__arrow announcement-bar__arrow--next" aria-label="Next">&#8594;</button>
  </div>
</div>

{% schema %}
{
  "name": "Announcement Bar",
  "settings": [
    {
      "type": "text",
      "id": "message_1",
      "label": "Message 1",
      "default": "Free shipping on orders over €50"
    },
    {
      "type": "text",
      "id": "message_2",
      "label": "Message 2",
      "default": "30-day money back guarantee"
    },
    {
      "type": "text",
      "id": "message_3",
      "label": "Message 3",
      "default": "Spring Sale — 40% off selected items"
    }
  ]
}
{% endschema %}
