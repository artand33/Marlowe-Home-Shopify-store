<section class="brand-story section-pad">
  <div class="brand-story__inner">
    <span class="label-tag">{{ 'sections.brand_story.label' | t }}</span>
    <h2 class="brand-story__heading">{{ 'sections.brand_story.heading' | t }}</h2>
    <div class="brand-story__body">
      {{ 'sections.brand_story.body' | t }}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Brand Story",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "t:sections.brand_story.heading"
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Body Text",
      "default": "t:sections.brand_story.body"
    }
  ],
  "presets": [{ "name": "Brand Story" }]
}
{% endschema %}
