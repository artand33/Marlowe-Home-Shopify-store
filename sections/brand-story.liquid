<section class="brand-story section-pad">
  <div class="brand-story__inner">
    <span class="label-tag">Our Story</span>
    <h2 class="brand-story__heading">{{ section.settings.heading | default: 'Welcome to Marlowe Home' }}</h2>
    <div class="brand-story__body">
      {{ section.settings.body | default: '<p>At Marlowe Home, we believe your space should feel as good as it looks. We curate lighting and ambiance products with one thing in mind — warmth.</p><p>Designed for the modern home. Inspired by British elegance.</p>' }}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Brand Story",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Welcome to Marlowe Home"
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Body Text",
      "default": "<p>At Marlowe Home, we believe your space should feel as good as it looks. We curate lighting and ambiance products with one thing in mind — warmth.</p><p>Designed for the modern home. Inspired by British elegance.</p>"
    }
  ],
  "presets": [{ "name": "Brand Story" }]
}
{% endschema %}
