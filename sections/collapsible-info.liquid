<section class="collapsible-info">
  <div class="collapsible-info__inner">

    <!-- Shipping Info -->
    <div class="accordion-item">
      <button class="accordion-trigger" aria-expanded="false">
        <span class="accordion-trigger__label">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><rect x="1" y="3" width="15" height="13" rx="1"/><path d="M16 8h4l3 5v3h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
          {{ section.settings.block_1_title | default: 'Shipping Info' }}
        </span>
        <span class="accordion-trigger__icon">+</span>
      </button>
      <div class="accordion-body">
        <div class="accordion-body__inner">{{ section.settings.block_1_body | default: '<p>We ship to Belgium, the Netherlands, and across the EU within 5–7 business days. All orders include full tracked delivery.</p><p><strong>Free shipping</strong> on orders over €50. Standard rate €4.95 for orders below €50.</p><p>You'll receive a tracking number via email as soon as your order ships.</p>' }}</div>
      </div>
    </div>

    <!-- Materials & Care -->
    <div class="accordion-item">
      <button class="accordion-trigger" aria-expanded="false">
        <span class="accordion-trigger__label">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M5.5 11h13M5.5 15h13M9 7h6m-6 12h6M9 3l-1 2h8l-1-2H9z"/></svg>
          {{ section.settings.block_2_title | default: 'Materials & Care' }}
        </span>
        <span class="accordion-trigger__icon">+</span>
      </button>
      <div class="accordion-body">
        <div class="accordion-body__inner">{{ section.settings.block_2_body | default: '<p><strong>Materials:</strong> Premium brass, linen, and hand-selected natural fibers. Every piece is tested for durability and warmth.</p><p><strong>Care Instructions:</strong> Wipe brass with a soft dry cloth to maintain the finish. Dust linen shades gently. Avoid abrasive cleaners and excessive moisture.</p><p>Please consult the product details for specific care guidance per item.</p>' }}</div>
      </div>
    </div>

    <!-- Returns Policy -->
    <div class="accordion-item">
      <button class="accordion-trigger" aria-expanded="false">
        <span class="accordion-trigger__label">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M3 12a9 9 0 0 1 9-9 9.75 9.75 0 0 1 6.74 2.74L21 8"/><path d="M21 3v5h-5M21 12a9 9 0 0 1-9 9 9.75 9.75 0 0 1-6.74-2.74L3 16"/><path d="M3 21v-5h5"/></svg>
          {{ section.settings.block_3_title | default: 'Returns Policy' }}
        </span>
        <span class="accordion-trigger__icon">+</span>
      </button>
      <div class="accordion-body">
        <div class="accordion-body__inner">{{ section.settings.block_3_body | default: '<p>We stand behind every product. If you\'re not completely satisfied within <strong>30 days</strong> of receiving your order, we\'ll arrange a full refund — no questions asked.</p><p><strong>Return conditions:</strong> Items must be returned in original condition and packaging, unused and unassembled.</p><p>Contact our team to arrange a return. We provide a prepaid return label for your convenience.</p>' }}</div>
      </div>
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Collapsible Info",
  "settings": [
    {
      "type": "text",
      "id": "block_1_title",
      "label": "Block 1 Title",
      "default": "Shipping Information"
    },
    {
      "type": "richtext",
      "id": "block_1_body",
      "label": "Block 1 Body",
      "default": "<p>We ship to Belgium and the Netherlands within 2-5 business days. All orders are tracked and you will receive a tracking link via email once your order is dispatched.</p>"
    },
    {
      "type": "text",
      "id": "block_2_title",
      "label": "Block 2 Title",
      "default": "Returns & Refund Policy"
    },
    {
      "type": "richtext",
      "id": "block_2_body",
      "label": "Block 2 Body",
      "default": "<p>We offer a 30-day money back guarantee. If you are not satisfied with your purchase, contact us within 30 days and we will arrange a full refund.</p>"
    },
    {
      "type": "text",
      "id": "block_3_title",
      "label": "Block 3 Title",
      "default": "Have a Question?"
    },
    {
      "type": "richtext",
      "id": "block_3_body",
      "label": "Block 3 Body",
      "default": "<p>Our customer support team is available Monday to Friday, 9am-6pm CET. Average response time is 24 hours.</p>"
    }
  ],
  "presets": [{ "name": "Collapsible Info" }]
}
{% endschema %}
