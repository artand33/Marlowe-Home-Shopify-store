<section class="community-trust section-pad">
  <div class="container">
    <span class="label-tag">Community</span>
    <h2 class="community-trust__heading">{{ section.settings.heading | default: 'The Marlowe Home Community' }}</h2>
    <p class="community-trust__sub">{{ section.settings.subheading | default: 'Join over 10,000 European homes that chose warmth.' }}</p>
    <div class="trustpilot-badge">
      <span class="trustpilot-badge__stars">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
      <span>Excellent · 4.8 out of 5</span>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Community Trust",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The Marlowe Home Community"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Join over 10,000 European homes that chose warmth."
    }
  ],
  "presets": [{ "name": "Community Trust" }]
}
{% endschema %}
