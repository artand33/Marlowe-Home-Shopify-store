<section class="contact-cta section-pad">
  <div class="container">
    <span class="label-tag">{{ 'sections.contact_cta.label' | t }}</span>
    <h2 class="contact-cta__heading">{{ 'sections.contact_cta.heading' | t }}</h2>
    <p class="contact-cta__body">{{ 'sections.contact_cta.body' | t }}</p>
    <a href="{{ section.settings.button_link | default: '/pages/contact' }}" class="btn btn-gold">
      {{ 'sections.contact_cta.button_label' | t }}
    </a>
  </div>
</section>

{% schema %}
{
  "name": "Contact CTA",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "t:sections.contact_cta.heading"
    },
    {
      "type": "text",
      "id": "body",
      "label": "Body Text",
      "default": "t:sections.contact_cta.body"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "t:sections.contact_cta.button_label"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    }
  ],
  "presets": [{ "name": "Contact CTA" }]
}
{% endschema %}
