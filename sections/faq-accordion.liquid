<section class="faq-section">
  <div class="faq-section__inner">

    <div class="faq-section__header">
      <h2 class="faq-section__heading">{{ 'sections.faq.heading' | t }}</h2>
      <span class="faq-section__underline"></span>
      <p class="faq-section__subheading">{{ 'sections.faq.subheading' | t }}</p>
    </div>

    <div class="faq-section__list">
      {%- for block in section.blocks -%}
        <div class="faq-item" {{ block.shopify_attributes }}>
          <button class="faq-trigger" aria-expanded="false">
            <span class="faq-trigger__text">{{ block.settings.question }}</span>
            <span class="faq-trigger__icon" aria-hidden="true">+</span>
          </button>
          <div class="faq-body">
            <div class="faq-body__inner">{{ block.settings.answer }}</div>
          </div>
        </div>
      {%- else -%}
        {%- comment %} Fallback hardcoded questions when no blocks are added yet {%- endcomment %}
        {%- for i in (1..6) -%}
          {%- assign q_key = 'sections.faq.q' | append: i | append: '_question' -%}
          {%- assign a_key = 'sections.faq.q' | append: i | append: '_answer' -%}
          <div class="faq-item">
            <button class="faq-trigger" aria-expanded="false">
              <span class="faq-trigger__text">{{ q_key | t }}</span>
              <span class="faq-trigger__icon" aria-hidden="true">+</span>
            </button>
            <div class="faq-body">
              <div class="faq-body__inner"><p>{{ a_key | t }}</p></div>
            </div>
          </div>
        {%- endfor -%}
      {%- endfor -%}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "FAQ Accordion",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "t:sections.faq.heading"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "t:sections.faq.subheading"
    }
  ],
  "blocks": [
    {
      "type": "faq_item",
      "name": "FAQ Item",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "Your question here"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Answer",
          "default": "<p>Your answer here.</p>"
        }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [
    {
      "name": "FAQ Accordion"
    }
  ]
}
{% endschema %}
