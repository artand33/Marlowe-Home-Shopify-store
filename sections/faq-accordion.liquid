<section class="faq-section">
  <div class="faq-section__inner">

    <div class="faq-section__header">
      <h2 class="faq-section__heading">{{ section.settings.heading | default: 'Frequently Asked Questions' }}</h2>
      <span class="faq-section__underline"></span>
      <p class="faq-section__subheading">{{ section.settings.subheading | default: 'Everything you need to know before you order.' }}</p>
    </div>

    <div class="faq-section__list">
      {%- for block in section.blocks -%}
        <div class="faq-item" {{ block.shopify_attributes }}>
          <button class="faq-trigger" aria-expanded="false">
            <span class="faq-trigger__text">{{ block.settings.question }}</span>
            <span class="faq-trigger__icon" aria-hidden="true">+</span>
          </button>
          <div class="faq-body">
            <div class="faq-body__inner">{{ block.settings.answer }}</div>
          </div>
        </div>
      {%- else -%}
        {%- comment %} Fallback hardcoded questions when no blocks are added yet {%- endcomment %}
        <div class="faq-item">
          <button class="faq-trigger" aria-expanded="false">
            <span class="faq-trigger__text">Do you ship to Belgium and the Netherlands?</span>
            <span class="faq-trigger__icon" aria-hidden="true">+</span>
          </button>
          <div class="faq-body">
            <div class="faq-body__inner"><p>Yes, we ship to Belgium, the Netherlands, and across the EU. Orders typically arrive within 5–7 business days with full tracked delivery.</p></div>
          </div>
        </div>
        <div class="faq-item">
          <button class="faq-trigger" aria-expanded="false">
            <span class="faq-trigger__text">What if I don't love my purchase?</span>
            <span class="faq-trigger__icon" aria-hidden="true">+</span>
          </button>
          <div class="faq-body">
            <div class="faq-body__inner"><p>We offer a 30-day money-back guarantee, no questions asked. If a piece doesn't feel right in your home, return it for a full refund.</p></div>
          </div>
        </div>
        <div class="faq-item">
          <button class="faq-trigger" aria-expanded="false">
            <span class="faq-trigger__text">Are your products tested for quality?</span>
            <span class="faq-trigger__icon" aria-hidden="true">+</span>
          </button>
          <div class="faq-body">
            <div class="faq-body__inner"><p>Every product is hand-selected and tested for quality, durability, and warmth. We only carry pieces we would place in our own homes.</p></div>
          </div>
        </div>
        <div class="faq-item">
          <button class="faq-trigger" aria-expanded="false">
            <span class="faq-trigger__text">Do you offer gift wrapping?</span>
            <span class="faq-trigger__icon" aria-hidden="true">+</span>
          </button>
          <div class="faq-body">
            <div class="faq-body__inner"><p>We offer premium gift packaging on select items. Contact our team before ordering to arrange this for someone special.</p></div>
          </div>
        </div>
        <div class="faq-item">
          <button class="faq-trigger" aria-expanded="false">
            <span class="faq-trigger__text">How do I track my order?</span>
            <span class="faq-trigger__icon" aria-hidden="true">+</span>
          </button>
          <div class="faq-body">
            <div class="faq-body__inner"><p>You will receive a tracking number by email as soon as your order ships. You can follow your package every step of the way.</p></div>
          </div>
        </div>
        <div class="faq-item">
          <button class="faq-trigger" aria-expanded="false">
            <span class="faq-trigger__text">How do I contact customer support?</span>
            <span class="faq-trigger__icon" aria-hidden="true">+</span>
          </button>
          <div class="faq-body">
            <div class="faq-body__inner"><p>Our team is available Monday to Friday, 9am to 6pm CET. Reach us via the contact page and we will respond within 24 hours.</p></div>
          </div>
        </div>
      {%- endfor -%}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "FAQ Accordion",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Frequently Asked Questions"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Everything you need to know before you order."
    }
  ],
  "blocks": [
    {
      "type": "faq_item",
      "name": "FAQ Item",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "Your question here"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Answer",
          "default": "<p>Your answer here.</p>"
        }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [
    {
      "name": "FAQ Accordion",
      "blocks": [
        {
          "type": "faq_item",
          "settings": {
            "question": "Do you ship to Belgium and the Netherlands?",
            "answer": "<p>Yes, we ship to Belgium, the Netherlands, and across the EU. Orders typically arrive within 5–7 business days with full tracked delivery.</p>"
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "question": "What if I don't love my purchase?",
            "answer": "<p>We offer a 30-day money-back guarantee, no questions asked. If a piece doesn't feel right in your home, return it for a full refund.</p>"
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "question": "Are your products tested for quality?",
            "answer": "<p>Every product is hand-selected and tested for quality, durability, and warmth. We only carry pieces we would place in our own homes.</p>"
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "question": "Do you offer gift wrapping?",
            "answer": "<p>We offer premium gift packaging on select items. Contact our team before ordering to arrange this for someone special.</p>"
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "question": "How do I track my order?",
            "answer": "<p>You will receive a tracking number by email as soon as your order ships. You can follow your package every step of the way.</p>"
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "question": "How do I contact customer support?",
            "answer": "<p>Our team is available Monday to Friday, 9am to 6pm CET. Reach us via the contact page and we will respond within 24 hours.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
