{%- assign featured = collections[section.settings.collection] -%}
{%- assign products_to_show = featured.products | default: collections.all.products -%}

<section class="featured-collection section-pad">
  <div class="container">
    <div class="section-header">
      <span class="label-tag">Featured</span>
      <h2 class="section-header__heading">{{ section.settings.heading | default: 'Best Sellers' }}</h2>
      <p class="section-header__sub">{{ section.settings.subheading | default: 'Our most loved pieces this season.' }}</p>
    </div>

    <div class="product-grid">
      {%- for product in products_to_show limit: 4 -%}
        {% render 'product-card', product: product %}
      {%- else -%}
        {%- for i in (1..4) -%}
          <div class="product-card">
            <div class="product-card__image-wrap">
              {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
            </div>
            <div class="product-card__body">
              <h3 class="product-card__title">Sample Product {{ i }}</h3>
              <div class="product-card__price">
                <span class="product-card__price-sale">€49.99</span>
                <span class="product-card__price-compare">€89.99</span>
              </div>
            </div>
          </div>
        {%- endfor -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured Collection",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Best Sellers"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Our most loved pieces this season."
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    }
  ],
  "presets": [{ "name": "Featured Collection" }]
}
{% endschema %}
