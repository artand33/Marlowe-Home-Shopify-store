<footer class="site-footer">
  <div class="footer__grid footer-columns">

    <div class="footer-col-brand">
    <!-- Col 1: Brand -->
    <div>
      <p class="footer__brand-tagline">Marlowe Home</p>
      <p class="footer__brand-body">
        {{ section.settings.brand_body | default: 'We believe your home should feel as good as it looks. Premium lighting and ambiance products, curated for the modern European home. Inspired by British elegance.' }}
      </p>
    </div>

    <!-- Col 2: Newsletter -->
    <div>
      <h3 class="footer__col-heading">{{ section.settings.newsletter_heading | default: 'Join the Marlowe Circle' }}</h3>
      <div class="footer__newsletter-form">
        {% form 'customer', id: 'footer-newsletter' %}
          <input type="hidden" name="contact[tags]" value="newsletter">
          <input
            type="email"
            name="contact[email]"
            class="footer__newsletter-input"
            placeholder="{{ section.settings.newsletter_placeholder | default: 'Your email address' }}"
            required
            autocomplete="email"
          >
          <button type="submit" class="btn btn-gold">
            {{ section.settings.newsletter_cta | default: 'Subscribe' }}
          </button>
        {% endform %}
      </div>
    </div>
    </div>

    <!-- Col 3: Shop Links -->
    <div>
      <h3 class="footer__col-heading">Shop</h3>
      <ul class="footer__links">
        <li><a href="/collections/all" class="footer__link">All Products</a></li>
        <li><a href="/collections" class="footer__link">Collections</a></li>
        <li><a href="/collections/sale" class="footer__link">Spring Sale</a></li>
        <li><a href="/pages/about" class="footer__link">About Us</a></li>
      </ul>
    </div>

    <!-- Col 4: Policies -->
    <div>
      <h3 class="footer__col-heading">Information</h3>
      <ul class="footer__links">
        <li><a href="/policies/privacy-policy" class="footer__link">Privacy Policy</a></li>
        <li><a href="/policies/refund-policy" class="footer__link">Returns &amp; Refunds</a></li>
        <li><a href="/policies/shipping-policy" class="footer__link">Shipping Policy</a></li>
        <li><a href="/policies/terms-of-service" class="footer__link">Terms of Service</a></li>
        <li><a href="/pages/contact" class="footer__link">Contact Us</a></li>
      </ul>
    </div>

  </div>

  <div class="footer__bottom">
    <p class="footer__copyright">
      &copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.
    </p>
    <div class="footer__payment-icons">
      <span class="footer__payment-icon">Visa</span>
      <span class="footer__payment-icon">MC</span>
      <span class="footer__payment-icon">Apple Pay</span>
      <span class="footer__payment-icon">Shop Pay</span>
      <span class="footer__payment-icon">iDEAL</span>
      <span class="footer__payment-icon">Bancontact</span>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "textarea",
      "id": "brand_body",
      "label": "Brand Description",
      "default": "We believe your home should feel as good as it looks. Premium lighting and ambiance products, curated for the modern European home. Inspired by British elegance."
    },
    {
      "type": "text",
      "id": "newsletter_heading",
      "label": "Newsletter Heading",
      "default": "Join the Marlowe Circle"
    },
    {
      "type": "text",
      "id": "newsletter_placeholder",
      "label": "Email Placeholder",
      "default": "Your email address"
    },
    {
      "type": "text",
      "id": "newsletter_cta",
      "label": "Newsletter Button Label",
      "default": "Subscribe"
    }
  ]
}
{% endschema %}
