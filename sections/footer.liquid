<footer class="site-footer">
  <div class="footer__grid footer-columns">

    <div class="footer-col-brand">
    <!-- Col 1: Brand -->
    <div>
      <p class="footer__brand-tagline">Marlowe Home</p>
      <p class="footer__brand-body">
        {{ 'footer.brand_body' | t }}
      </p>
    </div>

    <!-- Col 2: Newsletter -->
    <div>
      <h3 class="footer__col-heading">{{ 'footer.newsletter_heading' | t }}</h3>
      <div class="footer__newsletter-form">
        {% form 'customer', id: 'footer-newsletter' %}
          <input type="hidden" name="contact[tags]" value="newsletter">
          <input
            type="email"
            name="contact[email]"
            class="footer__newsletter-input"
            placeholder="{{ 'footer.newsletter_placeholder' | t }}"
            required
            autocomplete="email"
          >
          <button type="submit" class="btn btn-gold">
            {{ 'footer.newsletter_submit' | t }}
          </button>
        {% endform %}
      </div>
    </div>
    </div>

    <!-- Col 3: Shop Links -->
    <div>
      <h3 class="footer__col-heading">{{ 'footer.links.shop' | t }}</h3>
      <ul class="footer__links">
        <li><a href="/collections/all" class="footer__link">{{ 'footer.links.all_products' | t }}</a></li>
        <li><a href="/collections" class="footer__link">{{ 'footer.links.collections' | t }}</a></li>
        <li><a href="/collections/sale" class="footer__link">{{ 'footer.links.sale' | t }}</a></li>
        <li><a href="/pages/about" class="footer__link">{{ 'footer.links.about' | t }}</a></li>
      </ul>
    </div>

    <!-- Col 4: Policies -->
    <div>
      <h3 class="footer__col-heading">{{ 'footer.information_heading' | t }}</h3>
      <ul class="footer__links">
        <li><a href="/policies/privacy-policy" class="footer__link">{{ 'footer.policies.privacy' | t }}</a></li>
        <li><a href="/policies/refund-policy" class="footer__link">{{ 'footer.policies.returns' | t }}</a></li>
        <li><a href="/policies/shipping-policy" class="footer__link">{{ 'footer.policies.shipping' | t }}</a></li>
        <li><a href="/policies/terms-of-service" class="footer__link">{{ 'footer.policies.terms' | t }}</a></li>
        <li><a href="/pages/contact" class="footer__link">{{ 'footer.links.contact' | t }}</a></li>
      </ul>
    </div>

  </div>

  <div class="footer__bottom">
    <p class="footer__copyright">
      {%- assign _year = 'now' | date: '%Y' -%}
      {{ 'footer.copyright' | t: year: _year }}
    </p>
    <div class="footer__payment-icons">
      <span class="footer__payment-icon">Visa</span>
      <span class="footer__payment-icon">MC</span>
      <span class="footer__payment-icon">Apple Pay</span>
      <span class="footer__payment-icon">Shop Pay</span>
      <span class="footer__payment-icon">iDEAL</span>
      <span class="footer__payment-icon">Bancontact</span>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "textarea",
      "id": "brand_body",
      "label": "Brand Description",
      "default": "t:footer.brand_body",
      "info": "Edit text in Online Store → Themes → Edit default theme content."
    },
    {
      "type": "text",
      "id": "newsletter_heading",
      "label": "Newsletter Heading",
      "default": "t:footer.newsletter_heading",
      "info": "Edit text in Online Store → Themes → Edit default theme content."
    },
    {
      "type": "text",
      "id": "newsletter_placeholder",
      "label": "Email Placeholder",
      "default": "t:footer.newsletter_placeholder",
      "info": "Edit text in Online Store → Themes → Edit default theme content."
    },
    {
      "type": "text",
      "id": "newsletter_cta",
      "label": "Newsletter Button Label",
      "default": "t:footer.newsletter_submit",
      "info": "Edit text in Online Store → Themes → Edit default theme content."
    }
  ]
}
{% endschema %}
