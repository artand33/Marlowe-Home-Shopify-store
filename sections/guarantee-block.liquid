{%- assign guarantee_alt = 'sections.guarantee_block.heading' | t -%}
<section class="guarantee-block">
  <div class="guarantee-block__inner">

    <div class="guarantee-block__content">
      <span class="guarantee-block__label">{{ 'sections.guarantee_block.label' | t }}</span>
      <h2 class="guarantee-block__heading">{{ 'sections.guarantee_block.heading' | t }}</h2>
      <div class="guarantee-block__body">
        {{ 'sections.guarantee_block.body' | t }}
      </div>
      <a href="{{ section.settings.button_link | default: '/pages/returns' }}" class="btn btn-ghost">
        {{ 'sections.guarantee_block.button_label' | t }}
      </a>
    </div>

    <div class="guarantee-block__image">
      {%- if section.settings.image %}
        {{ section.settings.image | image_url: width: 800 | image_tag: loading: 'lazy', alt: guarantee_alt }}
      {%- else %}
        <div class="img-placeholder">
          <span class="img-placeholder__label">[ Upload guarantee lifestyle image ]</span>
        </div>
      {%- endif %}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Guarantee Block",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Label (above heading)",
      "default": "t:sections.guarantee_block.label"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "t:sections.guarantee_block.heading"
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Body Text",
      "default": "t:sections.guarantee_block.body"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "t:sections.guarantee_block.button_label"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Right Column Image",
      "info": "Warm lifestyle image. Recommended: 800 x 600px."
    }
  ],
  "presets": [{ "name": "Guarantee Block" }]
}
{% endschema %}
