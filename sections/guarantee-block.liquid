<section class="guarantee-block">
  <div class="guarantee-block__inner">
    <div class="guarantee-block__content">
      <span class="label-tag">Our Promise</span>
      <h2 class="guarantee-block__heading">{{ section.settings.heading | default: '30-Day Money Back Guarantee' }}</h2>
      <p class="guarantee-block__body">{{ section.settings.body | default: 'We stand behind every product we sell. If you\'re not completely satisfied within 30 days of receiving your order, we\'ll arrange a full refund — no questions asked.' }}</p>
      {%- if section.settings.button_label != blank %}
        <a href="{{ section.settings.button_link | default: '/pages/returns' }}" class="btn btn-ghost">
          {{ section.settings.button_label }}
        </a>
      {%- endif %}
    </div>

    <div class="guarantee-block__image">
      {%- if section.settings.image %}
        {{ section.settings.image | image_url: width: 700 | image_tag: loading: 'lazy', alt: section.settings.heading }}
      {%- else %}
        {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg' }}
      {%- endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Guarantee Block",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "30-Day Money Back Guarantee"
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Body Text",
      "default": "We stand behind every product we sell. If you're not completely satisfied within 30 days of receiving your order, we'll arrange a full refund — no questions asked."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Learn More"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    }
  ],
  "presets": [{ "name": "Guarantee Block" }]
}
{% endschema %}
