{%- assign hero_alt = 'sections.hero.heading' | t -%}
<section class="hero-banner">
  {%- if section.settings.image %}
    {{ section.settings.image | image_url: width: 1800 | image_tag: class: 'hero-banner__bg', loading: 'eager', fetchpriority: 'high', alt: hero_alt }}
  {%- else %}
    <div class="hero-banner__bg img-placeholder img-placeholder--hero">
      <span class="img-placeholder__label">[ Upload image here ]</span>
    </div>
  {%- endif %}

  <div class="hero-banner__overlay"></div>

  <div class="hero-banner__content">
    <span class="label-tag">{{ 'sections.hero.label' | t }}</span>
    <h1 class="hero-banner__heading">{{ 'sections.hero.heading' | t }}</h1>
    <p class="hero-banner__subheading">{{ 'sections.hero.subheading' | t }}</p>
    <a href="{{ section.settings.button_link | default: '/collections/all' }}" class="btn btn-gold">
      {{ 'sections.hero.button_label' | t }}
    </a>
  </div>
</section>

{% schema %}
{
  "name": "Hero Banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background Image",
      "info": "Use a dark, moody lifestyle image. Recommended: 1800 x 1000px."
    },
    {
      "type": "text",
      "id": "label",
      "label": "Label (above heading)",
      "default": "t:sections.hero.label",
      "info": "Edit text in Online Store → Themes → Edit default theme content."
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "t:sections.hero.heading",
      "info": "Edit text in Online Store → Themes → Edit default theme content."
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "t:sections.hero.subheading",
      "info": "Edit text in Online Store → Themes → Edit default theme content."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "t:sections.hero.button_label",
      "info": "Edit text in Online Store → Themes → Edit default theme content."
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    }
  ],
  "presets": [{ "name": "Hero Banner" }]
}
{% endschema %}
