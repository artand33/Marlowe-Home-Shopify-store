<section class="hero-banner">
  {%- if section.settings.image %}
    {{ section.settings.image | image_url: width: 1800 | image_tag: class: 'hero-banner__bg', loading: 'eager', fetchpriority: 'high', alt: section.settings.heading }}
  {%- else %}
    <div class="hero-banner__bg img-placeholder img-placeholder--hero">
      <span class="img-placeholder__label">[ Upload image here ]</span>
    </div>
  {%- endif %}

  <div class="hero-banner__overlay"></div>

  <div class="hero-banner__content">
    <span class="label-tag">{{ section.settings.label | default: 'New Collection' }}</span>
    <h1 class="hero-banner__heading">{{ section.settings.heading | default: 'Light Changes Everything' }}</h1>
    <p class="hero-banner__subheading">{{ section.settings.subheading | default: 'Discover premium lighting crafted for the home you deserve.' }}</p>
    {%- if section.settings.button_label != blank %}
      <a href="{{ section.settings.button_link | default: '/collections/all' }}" class="btn btn-gold">
        {{ section.settings.button_label }}
      </a>
    {%- endif %}
  </div>
</section>

{% schema %}
{
  "name": "Hero Banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background Image",
      "info": "Use a dark, moody lifestyle image. Recommended: 1800 x 1000px."
    },
    {
      "type": "text",
      "id": "label",
      "label": "Label (above heading)",
      "default": "New Collection"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Light Changes Everything"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Discover premium lighting crafted for the home you deserve."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    }
  ],
  "presets": [{ "name": "Hero Banner" }]
}
{% endschema %}
