{%- assign lifestyle_alt = 'sections.lifestyle_split.heading' | t -%}
<section class="lifestyle-split">
  <div class="lifestyle-split__inner">
    <div class="lifestyle-split__image">
      {%- if section.settings.image %}
        {{ section.settings.image | image_url: width: 900 | image_tag: loading: 'lazy', alt: lifestyle_alt }}
      {%- else %}
        <div class="img-placeholder">
          <span class="img-placeholder__label">[ Upload lifestyle image — different from hero ]</span>
        </div>
      {%- endif %}
    </div>

    <div class="lifestyle-split__content">
      <span class="label-tag">{{ 'sections.lifestyle_split.label' | t }}</span>
      <h2 class="lifestyle-split__heading">{{ 'sections.lifestyle_split.heading' | t }}</h2>

      <ul class="lifestyle-split__bullets">
        <li class="lifestyle-split__bullet">{{ 'sections.lifestyle_split.bullet_1' | t }}</li>
        <li class="lifestyle-split__bullet">{{ 'sections.lifestyle_split.bullet_2' | t }}</li>
        <li class="lifestyle-split__bullet">{{ 'sections.lifestyle_split.bullet_3' | t }}</li>
        <li class="lifestyle-split__bullet">{{ 'sections.lifestyle_split.bullet_4' | t }}</li>
      </ul>

      <a href="{{ section.settings.button_link | default: '/pages/about' }}" class="btn btn-ghost">
        {{ 'sections.lifestyle_split.button_label' | t }}
      </a>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Lifestyle Split",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Lifestyle Image"
    },
    {
      "type": "text",
      "id": "label",
      "label": "Label",
      "default": "t:sections.lifestyle_split.label"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "t:sections.lifestyle_split.heading"
    },
    {
      "type": "text",
      "id": "bullet_1",
      "label": "Bullet 1",
      "default": "t:sections.lifestyle_split.bullet_1"
    },
    {
      "type": "text",
      "id": "bullet_2",
      "label": "Bullet 2",
      "default": "t:sections.lifestyle_split.bullet_2"
    },
    {
      "type": "text",
      "id": "bullet_3",
      "label": "Bullet 3",
      "default": "t:sections.lifestyle_split.bullet_3"
    },
    {
      "type": "text",
      "id": "bullet_4",
      "label": "Bullet 4",
      "default": "t:sections.lifestyle_split.bullet_4"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "t:sections.lifestyle_split.button_label"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    }
  ],
  "presets": [{ "name": "Lifestyle Split" }]
}
{% endschema %}
