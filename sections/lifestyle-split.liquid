<section class="lifestyle-split">
  <div class="lifestyle-split__inner">
    <div class="lifestyle-split__image">
      {%- if section.settings.image %}
        {{ section.settings.image | image_url: width: 900 | image_tag: loading: 'lazy', alt: section.settings.heading }}
      {%- else %}
        <div class="img-placeholder">
          <span class="img-placeholder__label">[ Upload lifestyle image — different from hero ]</span>
        </div>
      {%- endif %}
    </div>

    <div class="lifestyle-split__content">
      <span class="label-tag">{{ section.settings.label | default: 'Why Marlowe' }}</span>
      <h2 class="lifestyle-split__heading">{{ section.settings.heading | default: 'Crafted for the way you live' }}</h2>

      <ul class="lifestyle-split__bullets">
        {%- if section.settings.bullet_1 != blank %}
          <li class="lifestyle-split__bullet">{{ section.settings.bullet_1 }}</li>
        {%- endif %}
        {%- if section.settings.bullet_2 != blank %}
          <li class="lifestyle-split__bullet">{{ section.settings.bullet_2 }}</li>
        {%- endif %}
        {%- if section.settings.bullet_3 != blank %}
          <li class="lifestyle-split__bullet">{{ section.settings.bullet_3 }}</li>
        {%- endif %}
        {%- if section.settings.bullet_4 != blank %}
          <li class="lifestyle-split__bullet">{{ section.settings.bullet_4 }}</li>
        {%- endif %}
      </ul>

      {%- if section.settings.button_label != blank %}
        <a href="{{ section.settings.button_link | default: '/pages/about' }}" class="btn btn-ghost">
          {{ section.settings.button_label }}
        </a>
      {%- endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Lifestyle Split",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Lifestyle Image"
    },
    {
      "type": "text",
      "id": "label",
      "label": "Label",
      "default": "Why Marlowe"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Crafted for the way you live"
    },
    {
      "type": "text",
      "id": "bullet_1",
      "label": "Bullet 1",
      "default": "Curated for Belgian & Dutch homes"
    },
    {
      "type": "text",
      "id": "bullet_2",
      "label": "Bullet 2",
      "default": "Premium materials, honest prices"
    },
    {
      "type": "text",
      "id": "bullet_3",
      "label": "Bullet 3",
      "default": "Designed to create atmosphere, not just light"
    },
    {
      "type": "text",
      "id": "bullet_4",
      "label": "Bullet 4",
      "default": "Every piece tested for warmth and quality"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Discover Our Story"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    }
  ],
  "presets": [{ "name": "Lifestyle Split" }]
}
{% endschema %}
