<section class="main-product">
  <div class="product-layout">

    <!-- Left: Gallery -->
    <div class="product-gallery">
      <div class="product-gallery__main">
        {%- if product.featured_image %}
          {{ product.featured_image | image_url: width: 900 | image_tag: id: 'main-product-image', loading: 'eager', alt: product.title }}
        {%- else %}
          {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
        {%- endif %}
      </div>

      {%- if product.images.size > 1 %}
        <div class="product-gallery__thumbs">
          {%- for image in product.images limit: 4 -%}
            <div
              class="product-gallery__thumb{% if forloop.first %} is-active{% endif %}"
              data-full-src="{{ image | image_url: width: 900 }}"
            >
              {{ image | image_url: width: 150 | image_tag: loading: 'lazy', alt: product.title }}
            </div>
          {%- endfor -%}
        </div>
      {%- endif %}
    </div>

    <!-- Right: Product Info -->
    <div class="product-info">

      <!-- Rating (above title) -->
      <div class="product-info__rating">
        <span class="product-info__stars">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
        <span class="product-info__rating-text">4.8 / 5.0 — based on 500+ reviews</span>
      </div>

      <h1 class="product-info__title">{{ product.title }}</h1>

      <!-- Price block -->
      <div class="product-info__price-block">
        <span class="product-info__price-sale">{{ product.price | money }}</span>
        {%- if product.compare_at_price > product.price %}
          <span class="product-info__price-compare">{{ product.compare_at_price | money }}</span>
          {%- assign savings = product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price -%}
          <span class="product-info__price-badge">Save {{ savings }}%</span>
        {%- endif %}
      </div>

      <!-- Trust icons -->
      <div class="product-info__trust-icons">
        <span class="product-info__trust-item">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="3" width="15" height="13" rx="1"/><path d="M16 8h4l3 5v3h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
          Free shipping over €50
        </span>
        <span class="product-info__trust-item">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          30-day money back
        </span>
        <span class="product-info__trust-item">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="4" width="22" height="16" rx="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>
          Secure payment
        </span>
      </div>

      <!-- Urgency -->
      <p class="product-info__urgency">
        🌿 Spring Sale — Only a few left at this price
      </p>

      <!-- Variant selector -->
      {%- unless product.has_only_default_variant %}
        <div class="product-info__variants">
          {%- for option in product.options_with_values -%}
            <div class="product-info__variant-label">{{ option.name }}</div>
            <div class="variant-options">
              {%- for value in option.values -%}
                <button class="variant-option{% if forloop.first %} is-selected{% endif %}">{{ value }}</button>
              {%- endfor -%}
            </div>
          {%- endfor -%}
        </div>
      {%- endunless %}

      <!-- Add to cart form -->
      {%- form 'product', product -%}
        <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
        <button
          type="submit"
          class="btn btn-gold btn-full product-info__atc"
          {%- unless product.available %} disabled{%- endunless %}
        >
          {%- if product.available %}
            Add to Cart
          {%- else %}
            Sold Out
          {%- endif %}
        </button>
      {%- endform -%}

      <p class="product-info__scarcity">
        Due to high demand, we recommend ordering soon. Stock is limited.
      </p>

      <div class="product-info__reassurance">
        <span>Free returns</span>
        <span>Ships in 2-5 days</span>
        <span>Tracked delivery</span>
      </div>

    </div>
  </div>
</section>

<!-- Sticky ATC (mobile) -->
<div class="sticky-atc" id="sticky-atc" style="display:none">
  <div class="sticky-atc__thumb">
    {%- if product.featured_image %}
      {{ product.featured_image | image_url: width: 100 | image_tag: loading: 'lazy', alt: product.title }}
    {%- endif %}
  </div>
  <div class="sticky-atc__info">
    <div class="sticky-atc__name">{{ product.title }}</div>
    <div class="sticky-atc__price">{{ product.price | money }}</div>
  </div>
  {%- form 'product', product, id: 'sticky-atc-form' -%}
    <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
    <button type="submit" class="btn btn-gold sticky-atc__btn">Add to Cart</button>
  {%- endform -%}
</div>

{% schema %}
{
  "name": "Main Product",
  "settings": [],
  "presets": [{ "name": "Main Product" }]
}
{% endschema %}
