{%- assign arrivals = collections[section.settings.collection] -%}
{%- assign arrival_products = arrivals.products | default: collections.all.products -%}

<style>
  .new-arrivals .carousel-wrapper {
    position: relative;
    overflow: visible;
  }

  .new-arrivals .carousel-track {
    overflow: hidden;
  }

  .new-arrivals .carousel-btn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 10;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: var(--color-accent-gold);
    color: var(--color-bg-dark);
    cursor: pointer;
    border: none;
    font-size: 18px;
  }

  .new-arrivals .carousel-btn--prev {
    left: 8px;
  }

  .new-arrivals .carousel-btn--next {
    right: 8px;
  }
</style>

<section class="new-arrivals section-pad">
  <div class="container">
    <div class="section-header">
      <span class="label-tag">Just In</span>
      <h2 class="section-header__heading section-header__heading--dark">{{ section.settings.heading | default: 'New Arrivals' }}</h2>
      <p class="section-header__sub">{{ section.settings.subheading | default: 'Fresh pieces for the season.' }}</p>
    </div>
  </div>

  <div class="carousel-wrapper">
    <button class="carousel-btn carousel-btn--prev" aria-label="Previous">&#8592;</button>
    <div class="carousel-track-container">
      <div class="carousel-track">
        {%- for product in arrival_products limit: 8 -%}
          {% render 'product-card', product: product, light: true %}
        {%- else -%}
          {%- for i in (1..5) -%}
            <div class="product-card product-card--light">
              <div class="product-card__image-wrap">
                {{ 'product-2' | placeholder_svg_tag: 'placeholder-svg' }}
              </div>
              <div class="product-card__body">
                <h3 class="product-card__title product-card__title--dark">New Arrival {{ i }}</h3>
                <div class="product-card__price">
                  <span class="product-card__price-sale">€39.99</span>
                  <span class="product-card__price-compare">€69.99</span>
                </div>
              </div>
            </div>
          {%- endfor -%}
        {%- endfor -%}
      </div>
    </div>
    <button class="carousel-btn carousel-btn--next" aria-label="Next">&#8594;</button>
  </div>
</section>

{% schema %}
{
  "name": "New Arrivals Carousel",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "New Arrivals"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Fresh pieces for the season."
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    }
  ],
  "presets": [{ "name": "New Arrivals Carousel" }]
}
{% endschema %}
