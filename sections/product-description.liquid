<section class="product-description">
  <div class="product-description__inner">
    <h2 class="product-description__heading">
      {{ section.settings.heading | default: '✨ Why You\'ll Love This' }}
    </h2>
    <div class="product-description__body">
      {%- if product.description != blank %}
        {{ product.description }}
      {%- else %}
        <p>Transform your space with this beautifully crafted piece. <strong>Designed to create atmosphere</strong>, not just light — every detail has been considered to bring warmth and elegance to your home.</p>
        <p>Whether you're setting the mood for an evening in, or simply elevating your everyday surroundings, this piece delivers the kind of ambiance that turns a house into a home.</p>
        <p>Crafted from <strong>premium materials</strong> and thoughtfully designed for the modern European interior.</p>
      {%- endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Product Description",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "✨ Why You'll Love This"
    }
  ],
  "presets": [{ "name": "Product Description" }]
}
{% endschema %}
