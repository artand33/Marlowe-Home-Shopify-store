<section class="product-specs">
  <div class="product-specs__inner">
    <h2 class="product-description__heading">{{ section.settings.heading | default: 'Product Details' }}</h2>

    <table class="specs-table">
      {%- if section.settings.spec_1_label != blank %}
        <tr>
          <td>{{ section.settings.spec_1_label }}</td>
          <td>{{ section.settings.spec_1_value }}</td>
        </tr>
      {%- endif %}
      {%- if section.settings.spec_2_label != blank %}
        <tr>
          <td>{{ section.settings.spec_2_label }}</td>
          <td>{{ section.settings.spec_2_value }}</td>
        </tr>
      {%- endif %}
      {%- if section.settings.spec_3_label != blank %}
        <tr>
          <td>{{ section.settings.spec_3_label }}</td>
          <td>{{ section.settings.spec_3_value }}</td>
        </tr>
      {%- endif %}
      {%- if section.settings.spec_4_label != blank %}
        <tr>
          <td>{{ section.settings.spec_4_label }}</td>
          <td>{{ section.settings.spec_4_value }}</td>
        </tr>
      {%- endif %}
      {%- if section.settings.spec_5_label != blank %}
        <tr>
          <td>{{ section.settings.spec_5_label }}</td>
          <td>{{ section.settings.spec_5_value }}</td>
        </tr>
      {%- endif %}
    </table>
  </div>
</section>

{% schema %}
{
  "name": "Product Details & Specs",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Product Details"
    },
    {
      "type": "text",
      "id": "spec_1_label",
      "label": "Spec 1 Label",
      "default": "Dimensions"
    },
    {
      "type": "text",
      "id": "spec_1_value",
      "label": "Spec 1 Value",
      "default": "Set in Shopify admin"
    },
    {
      "type": "text",
      "id": "spec_2_label",
      "label": "Spec 2 Label",
      "default": "Materials"
    },
    {
      "type": "text",
      "id": "spec_2_value",
      "label": "Spec 2 Value",
      "default": "Set in Shopify admin"
    },
    {
      "type": "text",
      "id": "spec_3_label",
      "label": "Spec 3 Label",
      "default": "Power Source"
    },
    {
      "type": "text",
      "id": "spec_3_value",
      "label": "Spec 3 Value",
      "default": "Set in Shopify admin"
    },
    {
      "type": "text",
      "id": "spec_4_label",
      "label": "Spec 4 Label",
      "default": "Care Instructions"
    },
    {
      "type": "text",
      "id": "spec_4_value",
      "label": "Spec 4 Value",
      "default": "Set in Shopify admin"
    },
    {
      "type": "text",
      "id": "spec_5_label",
      "label": "Spec 5 Label"
    },
    {
      "type": "text",
      "id": "spec_5_value",
      "label": "Spec 5 Value"
    }
  ],
  "presets": [{ "name": "Product Details & Specs" }]
}
{% endschema %}
