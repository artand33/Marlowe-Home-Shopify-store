<section class="product-specs">
  <div class="product-specs__inner">
    <h2 class="product-specs__heading">{{ section.settings.heading | default: 'Product Details' }}</h2>

    <div class="specs-list">
      {%- if section.settings.spec_1_label != blank %}
        <div class="specs-item">
          <div class="specs-item__icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M3 12h18M3 6h18M3 18h18"/><line x1="9" y1="9" x2="9" y2="15"/><line x1="15" y1="9" x2="15" y2="15"/></svg>
          </div>
          <div class="specs-item__content">
            <div class="specs-item__label">{{ section.settings.spec_1_label }}</div>
            <div class="specs-item__value">{{ section.settings.spec_1_value }}</div>
          </div>
        </div>
      {%- endif %}

      {%- if section.settings.spec_2_label != blank %}
        <div class="specs-item">
          <div class="specs-item__icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M5 3h14c1.1 0 2 .9 2 2v14c0 1.1-.9 2-2 2H5c-1.1 0-2-.9-2-2V5c0-1.1.9-2 2-2z"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
          </div>
          <div class="specs-item__content">
            <div class="specs-item__label">{{ section.settings.spec_2_label }}</div>
            <div class="specs-item__value">{{ section.settings.spec_2_value }}</div>
          </div>
        </div>
      {%- endif %}

      {%- if section.settings.spec_3_label != blank %}
        <div class="specs-item">
          <div class="specs-item__icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M13 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9z"/><polyline points="13 2 13 9 20 9"/></svg>
          </div>
          <div class="specs-item__content">
            <div class="specs-item__label">{{ section.settings.spec_3_label }}</div>
            <div class="specs-item__value">{{ section.settings.spec_3_value }}</div>
          </div>
        </div>
      {%- endif %}

      {%- if section.settings.spec_4_label != blank %}
        <div class="specs-item">
          <div class="specs-item__icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M7 8c0-1.1.9-2 2-2s2 .9 2 2-1 2-2 2-2-.9-2-2z"/><path d="M12 9v7c0 .6.4 1 1 1h3c.6 0 1-.4 1-1v-7M3 16h18v4H3z"/></svg>
          </div>
          <div class="specs-item__content">
            <div class="specs-item__label">{{ section.settings.spec_4_label }}</div>
            <div class="specs-item__value">{{ section.settings.spec_4_value }}</div>
          </div>
        </div>
      {%- endif %}

      {%- if section.settings.spec_5_label != blank %}
        <div class="specs-item">
          <div class="specs-item__icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm3.5-9c.83 0 1.5-.67 1.5-1.5S16.33 8 15.5 8 14 8.67 14 9.5s.67 1.5 1.5 1.5z"/></svg>
          </div>
          <div class="specs-item__content">
            <div class="specs-item__label">{{ section.settings.spec_5_label }}</div>
            <div class="specs-item__value">{{ section.settings.spec_5_value }}</div>
          </div>
        </div>
      {%- endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Product Details & Specs",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Product Details"
    },
    {
      "type": "text",
      "id": "spec_1_label",
      "label": "Spec 1 Label",
      "default": "Dimensions"
    },
    {
      "type": "text",
      "id": "spec_1_value",
      "label": "Spec 1 Value",
      "default": "Set in Shopify admin"
    },
    {
      "type": "text",
      "id": "spec_2_label",
      "label": "Spec 2 Label",
      "default": "Materials"
    },
    {
      "type": "text",
      "id": "spec_2_value",
      "label": "Spec 2 Value",
      "default": "Set in Shopify admin"
    },
    {
      "type": "text",
      "id": "spec_3_label",
      "label": "Spec 3 Label",
      "default": "Power Source"
    },
    {
      "type": "text",
      "id": "spec_3_value",
      "label": "Spec 3 Value",
      "default": "Set in Shopify admin"
    },
    {
      "type": "text",
      "id": "spec_4_label",
      "label": "Spec 4 Label",
      "default": "Care Instructions"
    },
    {
      "type": "text",
      "id": "spec_4_value",
      "label": "Spec 4 Value",
      "default": "Set in Shopify admin"
    },
    {
      "type": "text",
      "id": "spec_5_label",
      "label": "Spec 5 Label"
    },
    {
      "type": "text",
      "id": "spec_5_value",
      "label": "Spec 5 Value"
    }
  ],
  "presets": [{ "name": "Product Details & Specs" }]
}
{% endschema %}
