{%- assign quote_alt = 'sections.product_secondary_image.quote' | t -%}
<section class="product-secondary-image">
  {%- if section.settings.image %}
    {{ section.settings.image | image_url: width: 1800 | image_tag: loading: 'lazy', alt: quote_alt }}
  {%- elsif product.images[1] %}
    {{ product.images[1] | image_url: width: 1800 | image_tag: loading: 'lazy', alt: product.title }}
  {%- else %}
    <div style="width:100%;height:100%;background:var(--color-bg-dark);"></div>
  {%- endif %}
  <div class="product-secondary-image__overlay">
    <p class="product-secondary-image__quote">
      "{{ 'sections.product_secondary_image.quote' | t }}"
    </p>
  </div>
</section>

{% schema %}
{
  "name": "Product Secondary Image",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image",
      "info": "Override product image. Optional."
    },
    {
      "type": "text",
      "id": "quote",
      "label": "Pull Quote",
      "default": "t:sections.product_secondary_image.quote"
    }
  ],
  "presets": [{ "name": "Product Secondary Image" }]
}
{% endschema %}
