<section class="reviews-grid section-pad">
  <div class="container">
    <div class="section-header">
      <span class="label-tag">Reviews</span>
      <h2 class="section-header__heading section-header__heading--dark">{{ section.settings.heading | default: 'What Our Customers Say' }}</h2>
    </div>

    <div class="reviews-grid__grid">
      {%- for i in (1..4) -%}
        {%- assign title_key = 'review_' | append: i | append: '_title' -%}
        {%- assign text_key = 'review_' | append: i | append: '_text' -%}
        {%- assign author_key = 'review_' | append: i | append: '_author' -%}
        <div class="review-card">
          <div class="review-card__stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          <p class="review-card__title">{{ section.settings[title_key] | default: 'Absolutely love it!' }}</p>
          <p class="review-card__text">"{{ section.settings[text_key] | default: 'This product exceeded all my expectations. The quality is exceptional and delivery was quick to the Netherlands.' }}"</p>
          <span class="review-card__author">— {{ section.settings[author_key] | default: 'Verified Customer' }}</span>
          <div class="review-card__verified">&#10003; Verified Purchase</div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Reviews Grid",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What Our Customers Say"
    },
    {
      "type": "text",
      "id": "review_1_title",
      "label": "Review 1 Title",
      "default": "Absolutely love it!"
    },
    {
      "type": "textarea",
      "id": "review_1_text",
      "label": "Review 1 Text",
      "default": "This product exceeded all my expectations. The quality is exceptional and delivery was quick to the Netherlands."
    },
    {
      "type": "text",
      "id": "review_1_author",
      "label": "Review 1 Author",
      "default": "Lena B., Amsterdam"
    },
    {
      "type": "text",
      "id": "review_2_title",
      "label": "Review 2 Title",
      "default": "Perfect for our living room"
    },
    {
      "type": "textarea",
      "id": "review_2_text",
      "label": "Review 2 Text",
      "default": "The warmth it creates in our space is exactly what we were looking for. Premium quality at a fair price."
    },
    {
      "type": "text",
      "id": "review_2_author",
      "label": "Review 2 Author",
      "default": "Marc D., Brussels"
    },
    {
      "type": "text",
      "id": "review_3_title",
      "label": "Review 3 Title",
      "default": "Beautiful craftsmanship"
    },
    {
      "type": "textarea",
      "id": "review_3_text",
      "label": "Review 3 Text",
      "default": "Ordered this as a gift and it was a huge hit. The packaging was gorgeous and the product itself is stunning."
    },
    {
      "type": "text",
      "id": "review_3_author",
      "label": "Review 3 Author",
      "default": "Sophie W., Antwerp"
    },
    {
      "type": "text",
      "id": "review_4_title",
      "label": "Review 4 Title",
      "default": "Worth every euro"
    },
    {
      "type": "textarea",
      "id": "review_4_text",
      "label": "Review 4 Text",
      "default": "I was hesitant about the price but after seeing it in person I understood immediately. This is genuine quality."
    },
    {
      "type": "text",
      "id": "review_4_author",
      "label": "Review 4 Author",
      "default": "Jan V., Rotterdam"
    }
  ],
  "presets": [{ "name": "Reviews Grid" }]
}
{% endschema %}
