<section class="reviews-grid">
  <div class="reviews-grid__inner">

    <div class="reviews-grid__header">
      <span class="label-tag">{{ 'sections.reviews_grid.label' | t }}</span>
      <h2 class="reviews-grid__heading">{{ 'sections.reviews_grid.heading' | t }}</h2>
      <span class="reviews-grid__underline"></span>
      <div class="reviews-grid__summary">
        {%- assign rating_value = section.settings.rating | default: '4.8' -%}
        {%- assign count_value = section.settings.review_count | default: '500+' -%}
        <span class="reviews-grid__stars" aria-label="{{ 'sections.reviews_grid.stars_label' | t: rating: rating_value }}">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
        <span class="reviews-grid__summary-text">{{ 'sections.reviews_grid.summary_text' | t: rating: rating_value, count: count_value }}</span>
      </div>
    </div>

    <div class="reviews-grid__grid">

      {%- for i in (1..3) -%}
        {%- assign rating_key = 'review_' | append: i | append: '_rating' -%}
        {%- assign rating_val = section.settings[rating_key] | default: 5 | plus: 0 -%}

        {%- assign title_locale  = 'sections.reviews_grid.review_' | append: i | append: '_title' -%}
        {%- assign text_locale   = 'sections.reviews_grid.review_' | append: i | append: '_text' -%}
        {%- assign author_locale = 'sections.reviews_grid.review_' | append: i | append: '_author' -%}
        {%- assign date_locale   = 'sections.reviews_grid.review_' | append: i | append: '_date' -%}

        <div class="review-card">
          <div class="review-card__top">
            <div class="review-card__stars" aria-label="{{ 'sections.reviews_grid.card_stars_label' | t: rating: rating_val }}">
              {%- for s in (1..rating_val) -%}&#9733;{%- endfor -%}
              {%- assign empty = 5 | minus: rating_val -%}
              {%- for s in (1..empty) -%}<span class="review-card__star--empty">&#9733;</span>{%- endfor -%}
            </div>
            <span class="review-card__date">{{ date_locale | t }}</span>
          </div>
          <p class="review-card__title">{{ title_locale | t }}</p>
          <p class="review-card__text">&ldquo;{{ text_locale | t }}&rdquo;</p>
          <div class="review-card__footer">
            <span class="review-card__author">{{ author_locale | t }}</span>
            <span class="review-card__verified">&#10003; {{ 'sections.reviews_grid.verified_purchase' | t }}</span>
          </div>
        </div>

      {%- endfor -%}

    </div>

  </div>
</section>

{% schema %}
