<section class="social-proof section-pad">
  <div class="container text-center">
    <span class="label-tag">{{ 'sections.social_proof_reviews.label' | t }}</span>
    <h2 class="social-proof__heading">{{ 'sections.social_proof_reviews.heading' | t }}</h2>
    <div class="social-proof__stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>

    <div class="reviews-strip">
      <div class="review-card">
        <div class="review-card__stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
        <p class="review-card__text">"{{ 'sections.social_proof_reviews.review_1_text' | t }}"</p>
        <span class="review-card__author">— {{ 'sections.social_proof_reviews.review_1_author' | t }}</span>
      </div>

      <div class="review-card">
        <div class="review-card__stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
        <p class="review-card__text">"{{ 'sections.social_proof_reviews.review_2_text' | t }}"</p>
        <span class="review-card__author">— {{ 'sections.social_proof_reviews.review_2_author' | t }}</span>
      </div>

      <div class="review-card">
        <div class="review-card__stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
        <p class="review-card__text">"{{ 'sections.social_proof_reviews.review_3_text' | t }}"</p>
        <span class="review-card__author">— {{ 'sections.social_proof_reviews.review_3_author' | t }}</span>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Social Proof / Reviews",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "t:sections.social_proof_reviews.heading"
    },
    {
      "type": "textarea",
      "id": "review_1_text",
      "label": "Review 1 Text",
      "default": "t:sections.social_proof_reviews.review_1_text"
    },
    {
      "type": "text",
      "id": "review_1_author",
      "label": "Review 1 Author",
      "default": "t:sections.social_proof_reviews.review_1_author"
    },
    {
      "type": "textarea",
      "id": "review_2_text",
      "label": "Review 2 Text",
      "default": "t:sections.social_proof_reviews.review_2_text"
    },
    {
      "type": "text",
      "id": "review_2_author",
      "label": "Review 2 Author",
      "default": "t:sections.social_proof_reviews.review_2_author"
    },
    {
      "type": "textarea",
      "id": "review_3_text",
      "label": "Review 3 Text",
      "default": "t:sections.social_proof_reviews.review_3_text"
    },
    {
      "type": "text",
      "id": "review_3_author",
      "label": "Review 3 Author",
      "default": "t:sections.social_proof_reviews.review_3_author"
    }
  ],
  "presets": [{ "name": "Social Proof Reviews" }]
}
{% endschema %}
