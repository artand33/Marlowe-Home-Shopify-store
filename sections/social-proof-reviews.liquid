<section class="social-proof section-pad">
  <div class="container text-center">
    <span class="label-tag">Customer Love</span>
    <h2 class="social-proof__heading">{{ section.settings.heading | default: 'Trusted by 10,000+ Homes Across Europe' }}</h2>
    <div class="social-proof__stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>

    <div class="reviews-strip">
      <div class="review-card">
        <div class="review-card__stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
        <p class="review-card__text">"{{ section.settings.review_1_text | default: 'Absolutely stunning. The quality is incredible and delivery was super fast to Belgium. My living room has never looked so warm and inviting.' }}"</p>
        <span class="review-card__author">— {{ section.settings.review_1_author | default: 'Sophie V.' }}</span>
      </div>

      <div class="review-card">
        <div class="review-card__stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
        <p class="review-card__text">"{{ section.settings.review_2_text | default: 'Finally a lighting brand that gets it. Premium quality, warm aesthetic - everything looks exactly as described. 100% recommend.' }}"</p>
        <span class="review-card__author">— {{ section.settings.review_2_author | default: 'Thomas K.' }}</span>
      </div>

      <div class="review-card">
        <div class="review-card__stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
        <p class="review-card__text">"{{ section.settings.review_3_text | default: 'Ordered twice now. The candle holders are a masterpiece. My guests always ask where I bought them. Love Marlowe Home!' }}"</p>
        <span class="review-card__author">— {{ section.settings.review_3_author | default: 'Emma D.' }}</span>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Social Proof / Reviews",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Trusted by 10,000+ Homes Across Europe"
    },
    {
      "type": "textarea",
      "id": "review_1_text",
      "label": "Review 1 Text",
      "default": "Absolutely stunning. The quality is incredible and delivery was super fast to Belgium. My living room has never looked so warm and inviting."
    },
    {
      "type": "text",
      "id": "review_1_author",
      "label": "Review 1 Author",
      "default": "Sophie V."
    },
    {
      "type": "textarea",
      "id": "review_2_text",
      "label": "Review 2 Text",
      "default": "Finally a lighting brand that gets it. Premium quality, warm aesthetic - everything looks exactly as described. 100% recommend."
    },
    {
      "type": "text",
      "id": "review_2_author",
      "label": "Review 2 Author",
      "default": "Thomas K."
    },
    {
      "type": "textarea",
      "id": "review_3_text",
      "label": "Review 3 Text",
      "default": "Ordered twice now. The candle holders are a masterpiece. My guests always ask where I bought them. Love Marlowe Home!"
    },
    {
      "type": "text",
      "id": "review_3_author",
      "label": "Review 3 Author",
      "default": "Emma D."
    }
  ],
  "presets": [{ "name": "Social Proof Reviews" }]
}
{% endschema %}
